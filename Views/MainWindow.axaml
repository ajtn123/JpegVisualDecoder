<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JpegVisualDecoder.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="JpegVisualDecoder.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.ico"
        Title="{Binding Path}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="*,*" RowDefinitions="3*,*">
        <ContentControl Content="{Binding ByteReaderViewModel}"/>
        <ContentControl Content="{Binding LoggerViewModel}" Grid.Row="1"/>
        <ContentControl Content="{Binding CompositeCanvasViewModel}" Grid.Column="1" Grid.RowSpan="2"/>

        <StackPanel Grid.Column="1" Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Orientation="Horizontal">
            <ToggleButton Content="Loop" Tapped="ToggleButton_Tapped"/>
            <Button Content="Restart" Tapped="Button_Tapped"/>
            <Button Content="About" Tapped="Button_Tapped_1"/>
            <Button Content="Close" Tapped="Button_Tapped_2"/>
        </StackPanel>
    </Grid>

</Window>
