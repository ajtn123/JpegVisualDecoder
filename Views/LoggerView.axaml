<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:JpegVisualDecoder.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:LoggerViewModel"
             x:Class="JpegVisualDecoder.Views.LoggerView">
    <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Logs}">
		    <ItemsControl.ItemTemplate>
			    <DataTemplate DataType="vm:Log">
				    <Grid ColumnDefinitions="75,75,*" ColumnSpacing="5">
					    <TextBlock Text="{Binding Position}" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="Gray"/>
                        <TextBlock Text="{Binding Category}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="DarkGray" Grid.Column="1"/>
                        <TextBlock Text="{Binding Message}" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" Grid.Column="2"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
